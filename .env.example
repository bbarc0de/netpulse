# Optional: an authorized, small HTTPS resource with permissive CORS headers.
# Connection Black Box uses it only for independent reachability timing.
# Add the same origin to the production Content-Security-Policy connect-src list.
VITE_MONITOR_SECONDARY_URL=

# Optional HTTPS endpoint-directory override. The default same-origin directory
# is /network/endpoints.v1.json. External directories require permissive CORS
# and an explicit production CSP connect-src entry. Never put signing secrets
# or provider credentials in this browser-visible variable.
VITE_NETPULSE_ENDPOINT_MANIFEST_URL=

# Development-only switch used by the isolated validation lab. Never enable
# this in a production build: it permits HTTP endpoints on the private Docker
# network and exposes a sanitized in-page result hook to the browser runner.
VITE_NETPULSE_LAB_MODE=false

# Area Pulse remains read-only/unavailable unless every required server value is configured.
# Use a provider-neutral, pooled PostgreSQL connection with a least-privilege application role.
DATABASE_URL=
AREA_PULSE_HASH_SECRET=
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
AREA_PULSE_EXPECTED_HOSTNAME=
AREA_PULSE_INGEST_TOKEN=
# Vercel supplies CRON_SECRET for cron requests; use this only outside Vercel.
AREA_PULSE_MAINTENANCE_TOKEN=
